# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
DEBUG=true
APP_NAME="Bakery API"
APP_VERSION="1.0.0"
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8080

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://bakery_user:bakery_pass@localhost:5432/bakery_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_secret_string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── Cookie Settings ───────────────────────────────────────────────────────────
COOKIE_SECURE=false               # set true in production (HTTPS only)
COOKIE_SAMESITE=lax               # lax | strict | none

# ── Google reCAPTCHA v3 ───────────────────────────────────────────────────────
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
RECAPTCHA_SCORE_THRESHOLD=0.5

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=noreply@bakery.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
